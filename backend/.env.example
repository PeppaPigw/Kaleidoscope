# Kaleidoscope Backend Environment Variables
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=Kaleidoscope
DEBUG=true

# --- PostgreSQL ---
DATABASE_URL=postgresql+asyncpg://kaleidoscope:kaleidoscope@localhost:5432/kaleidoscope

# --- Redis ---
REDIS_URL=redis://localhost:6379/0

# --- Neo4j ---
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=kaleidoscope

# --- Qdrant ---
QDRANT_URL=http://localhost:6333

# --- Meilisearch ---
MEILI_URL=http://localhost:7700
MEILI_MASTER_KEY=kaleidoscope-meili-key

# --- MinIO / S3 ---
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=kaleidoscope
MINIO_SECRET_KEY=kaleidoscope
MINIO_BUCKET=kaleidoscope-papers
MINIO_SECURE=false

# --- GROBID ---
GROBID_URL=http://localhost:8070

# --- External API Keys ---
UNPAYWALL_EMAIL=your-email@example.com
ELSEVIER_TDM_API_KEY=
WILEY_TOKEN=
SPRINGER_API_KEY=
OPENAI_API_KEY=sk-...

# --- Celery ---
CELERY_BROKER_URL=redis://localhost:6379/1
CELERY_RESULT_BACKEND=redis://localhost:6379/2

# --- RSS ---
RSS_POLL_INTERVAL_MINUTES=30
