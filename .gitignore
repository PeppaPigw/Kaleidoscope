# ═══════════════════════════════════════════════════════
#  Kaleidoscope — .gitignore
# ═══════════════════════════════════════════════════════

# ── OS ────────────────────────────────────────────────
.DS_Store
Thumbs.db
*.swp
*.swo

# ── IDE ───────────────────────────────────────────────
.vscode/
.idea/
*.iml

# ── Python (backend) ─────────────────────────────────
__pycache__/
*.py[cod]
*.egg-info/
*.egg
.venv/
venv/
.mypy_cache/
.pytest_cache/
.ruff_cache/
htmlcov/
.coverage

# ── Node (frontend) ──────────────────────────────────
node_modules/
.nuxt/
.output/
dist/
*.tsbuildinfo

# ── Environment & Secrets ────────────────────────────
.env
!.env.example
backend/.env
!backend/.env.example

# ── Docker volumes (local dev) ───────────────────────
docker-data/

# ── Logs ─────────────────────────────────────────────
*.log
logs/

# ── AI / Agent tooling (local only) ──────────────────
.history/
.trellis/
.agent/
.repo/
.claude/
.worktrees/
.worktrees/
skills/
AGENTS.md

docs/
.playwright-cli/

backend/tests
frontend/tests
frontend/test-results/*

output/

backend/scripts/
.cursor/
.github
.omx
