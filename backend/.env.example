# Kaleidoscope Backend Environment Variables
# Copy this file to .env and fill in your values

# --- Application ---
APP_NAME=Kaleidoscope
DEBUG=true

# --- PostgreSQL ---
DATABASE_URL=

# --- Redis ---
REDIS_URL=

# --- Neo4j ---
NEO4J_URI=
NEO4J_USER=
NEO4J_PASSWORD=

# --- Qdrant ---
QDRANT_URL=

# --- Meilisearch ---
MEILI_URL=
MEILI_MASTER_KEY=

# --- MinIO / S3 ---
MINIO_ENDPOINT=
MINIO_ACCESS_KEY=
MINIO_SECRET_KEY=
MINIO_BUCKET=
MINIO_SECURE=

# --- GROBID ---
GROBID_URL=

# --- External API Keys ---
UNPAYWALL_EMAIL=
ELSEVIER_TDM_API_KEY=
WILEY_TOKEN=
SPRINGER_OPEN_ACCESS_KEY=
SPRINGER_META_KEY=

# --- OPENAI ---
OPEN_BASE_URL=
OPENAI_API_KEY=

# --- TRANSLATE ---
TRANSLATE_BASE_URL=
TRANSLATE_MODEL=
TRANSLATE_API_KEY=

# --- BLSC LLM API (chat, embed, rerank) ---
# All three models share the same base URL and API key.
LLM_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
EMBED_MODEL=
RERANK_MODEL=

# --- MinerU ---
MINERU_API_TOKEN=

# --- Celery ---
CELERY_BROKER_URL=
CELERY_RESULT_BACKEND=

# --- RSS ---
RSS_POLL_INTERVAL_MINUTES=

# Image Host
IMG_HOST_ACCESS_KEY=
IMG_HOST_ACCESS_KEY_SECRET=
IMG_HOST_BUCKET_NAME=
IMG_HOST_URL=
